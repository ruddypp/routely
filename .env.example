# Core mode and storage
ROUTELY_ENV=development
ROUTELY_DATA_DIR=.routely
ROUTELY_DATABASE_URL=file:.routely/routely.db

# Local dashboard and daemon defaults
ROUTELY_DASHBOARD_PORT=3030
ROUTELY_DAEMON_HOST=127.0.0.1
ROUTELY_DAEMON_PORT=9977
ROUTELY_DAEMON_URL=http://127.0.0.1:9977

# Optional workspace/install overrides
ROUTELY_WORKSPACE_ROOT=
ROUTELY_REPO_ROOT=

# Production server settings
# Canonical daemon production switch. Use `production` on a VPS; leave `local`
# or empty for localhost development.
ROUTELY_SERVER_MODE=local
ROUTELY_ADMIN_TOKEN=
ROUTELY_SERVER_PUBLIC_IP=

# GitHub App integration. Keep these server-side only.
# Routely loads this file with dotenv. Do not shell-source `.env` when values
# include multiline secrets such as GitHub private keys. For shell workflows,
# export variables directly or encode multiline values with literal \n escapes.
ROUTELY_GITHUB_APP_ID=
ROUTELY_GITHUB_PRIVATE_KEY=
ROUTELY_GITHUB_WEBHOOK_SECRET=
ROUTELY_GITHUB_CLIENT_ID=
ROUTELY_GITHUB_CLIENT_SECRET=
